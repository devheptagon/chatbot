# Server
PORT=4444
NODE_ENV=development
API_DOMAIN=
PUBLIC_API_URL=/chatbot
ALLOWED_ORIGINS=*

# Gemini (AI Studio)
INFERENCE_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent
INFERENCE_TOKEN=

# Cerebras fast path (first N requests per client)
FAST_INFERENCE_URL=https://api.cerebras.ai/v1/chat/completions
FAST_INFERENCE_TOKEN=
FAST_INFERENCE_MODEL=gpt-oss-120b
FAST_REQUEST_LIMIT=3

# Gemini model settings
GEMINI_MODEL=gemini-2.5-flash-lite
SYSTEM_INSTRUCTION=You are a helpful assistant for my website.
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_TEMPERATURE=0.4

# Widget
WIDGET_TITLE=Chat with us
WIDGET_PLACEHOLDER=Type your message...
WIDGET_PRIMARY_COLOR=#2563eb
WIDGET_POSITION=bottom-right

# RAG (requires DATABASE_URL + pgvector table)
RAG_ENABLED=true
RAG_DOCS_PATH=./docs
RAG_TOP_K=3
RAG_MAX_CHUNK_CHARS=1200
RAG_MIN_SCORE=0.55
RAG_EMBEDDING_MODEL=gemini-embedding-001
RAG_EMBEDDING_DIMENSIONS=768
RAG_EMBEDDING_BATCH_SIZE=32
RAG_SYNC_ON_STARTUP=false

# Limits
MAX_BODY_BYTES=32768
MAX_MESSAGE_CHARS=2000
MAX_HISTORY_TURNS=20
SUMMARIZE_ENABLED=true
SUMMARIZE_EVERY_N_TURNS=5
SUMMARIZE_MAX_OUTPUT_TOKENS=512
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_CHAT_MAX=30
RATE_LIMIT_BURST_MAX=5
RATE_LIMIT_CHAT_PER_APP_MAX=30
RATE_LIMIT_BURST_PER_APP_MAX=5
RATE_LIMIT_DAILY_PER_IP_MAX=100
RATE_LIMIT_DAILY_PER_APP_MAX=100
DAILY_API_CALL_LIMIT=500

# Persistence
USAGE_STORE_PATH=./data/usage.json
CLIENT_ROUTING_STORE_PATH=./data/client-routing.json
DATABASE_URL=
